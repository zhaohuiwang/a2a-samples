{
    "version": "0.2.0",
    "configurations": [
    
        {
      "name": "Debug Skills Agent",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/skills_agent/main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "cwd": "${workspaceFolder}",
      "args": ["--host", "localhost", "--port", "10999"]
    }
    ]
}